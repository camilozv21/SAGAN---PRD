FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_PATH=./instance/portal.db

# Users are managed via the CLI:
#   flask create-user --email andrew@example.com --name "Andrew"
#   flask create-user --email rebecca@example.com --name "Rebecca"
#   flask create-user --email maryann@example.com --name "Maryann"
# Passwords are prompted interactively and bcrypt-hashed.
